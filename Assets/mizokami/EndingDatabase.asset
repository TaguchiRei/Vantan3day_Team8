    EndingTexts:
    - Type: 0
      Text: "\u4ECA\u65E5\u306E\u4ED5\u4E8B\u306F\u3053\u3053\u307E\u3067\uFF01"
  - Type: 2
    Sprite: {fileID: 21300000, guid: 575dc4c8b64231c48978845755e09cbb, type: 3}
    EndingTexts:
    - Type: 0
      Text: "\u50D5\u304C\u6607\u9032\uFF01\uFF1F\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3059\uFF01\uFF01"
  - Type: 3
    Sprite: {fileID: -998980191270683905, guid: 0b1e1ee11f387b44c8bfc36f4cb71a51, type: 3}
    EndingTexts:
    - Type: 0
      Text: "\u3048\u3047\u2026\u50D5\u306E\u7D50\u5A5A\u76F8\u624B\u4E0A\u53F8\u304B\u3088\uFF01\uFF1F"
  - Type: 4
    Sprite: {fileID: -2551333357017747867, guid: 5105318dcf41ba14d8aa2d3f8888eb4f, type: 3}
    EndingTexts:
    - Type: 0
      Text: "\u30DF\u30E5\u30A6\u3001\u805E\u3044\u3066\u304F\u308C\uFF01\u983C\u3080\u304B\u3089\uFF01\uFF1F"
  - Type: 5
    Sprite: {fileID: 950548923782038024, guid: aab8c81372b9fc94989b5d5e36f23db3, type: 3}
    EndingTexts:
    - Type: 0
      Text: "\u4FFA\u3001\u4F55\u304B\u53EC\u559A\u3057\u3061\u3083\u3044\u307E\u3057\u305F\uFF1F"
    - Type: 1
      Text: " \u5951\u7D04\u66F8\u306F\u4F1A\u793E\u5370\u3060\uFF01\u305D\u3046\u3060\u3001\u4FFA\u304C\u547C\u3073\u51FA\u3057\u305F\u3093\u3058\u3083\u306A\u3044\uFF01"
